# Your Anthropic API key. Without it the app runs in demo mode.
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model. Default is claude-sonnet-5 (fast, strong for
# structured drafting). For maximum depth on complex workpapers use
# claude-opus-4-8 (slower, higher cost).
ANTHROPIC_MODEL=claude-sonnet-5

# Optional: port (default 3000)
PORT=3000

# ---- Authentication ---------------------------------------------------------
# Set AUTH_PASSWORD to require login before anyone can spend your API budget.
# When unset, the app is OPEN (anyone who can reach it can generate). A console
# warning is printed in open mode.
AUTH_PASSWORD=

# Optional: a separate admin password. When set, only admins may use the Skill
# Studio (research + save). Users who log in with AUTH_PASSWORD get generate +
# read-only skill browsing. When unset, any logged-in user is an admin.
ADMIN_PASSWORD=

# Signs session cookies. Set a long random value in production so sessions
# survive restarts and can't be forged. A random secret is generated at startup
# if unset (sessions reset on restart).
SESSION_SECRET=

# ---- Skill Studio writes ----------------------------------------------------
# Whether the Skill Studio may research + write references. Default: enabled
# only when AUTH_PASSWORD is set (safe-by-default). Force with true/false.
# In open mode (no AUTH_PASSWORD) writes stay OFF unless SKILL_WRITE=true.
SKILL_WRITE=

# ---- Rate limiting (per IP, 15-minute window) -------------------------------
RATE_LIMIT_GENERATE=30
RATE_LIMIT_IMPROVE=10
RATE_LIMIT_LOGIN=10

# Set when running behind a reverse proxy / load balancer so client IPs are
# read from X-Forwarded-For (needed for correct rate limiting and Secure
# cookies). Use "true", a hop count, or a trusted subnet.
TRUST_PROXY=
